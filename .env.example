BASE_URL=https://your-app-url.com/
APP_USERNAME=your-username
APP_PASSWORD=your-password

HEADLESS=false
BROWSER=chromium
SLOW_MO=0
TIMEOUT=30000
RETRIES=1
WORKERS=2
