# Normalize line endings to LF for all text files across platforms
* text=auto eol=lf

# Explicitly declare TypeScript / JS as text
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf

# Jenkinsfile (no extension)
Jenkinsfile text eol=lf

# Binaries — never mangle
*.png  binary
*.jpg  binary
*.zip  binary
*.pdf  binary
